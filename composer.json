{
    "name": "php-surface/php-surface",
    "description": "Structural explorer for PHP source files",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "voku/simple-php-code-parser": "^0.21"
    },
    "autoload": {
        "psr-4": {
            "PhpSurface\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/php-surface"
    ],
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "lint": "phpcs --standard=PSR12 -p -s src",
        "test": "pest"
    },
    "require-dev": {
        "pestphp/pest": "^2.36"
    }
}
